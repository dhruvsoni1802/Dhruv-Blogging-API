# Production template — copy to .env.production for local prod testing (npm run start).
# On Railway/Render/Fly.io, set the same vars in the host dashboard (do not commit .env.production).
# Use a SEPARATE Supabase project from development.

NODE_ENV=production
PORT=3000

# Prod Supabase project
SUPABASE_URL=https://your-prod-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-prod-key

ADMIN_API_KEY=your-prod-admin-key
METRICS_API_KEY=your-prod-metrics-key
CORS_ORIGIN=https://your-frontend-domain.com

DEFAULT_KEY_EXPIRY_HOURS=24
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

SEARCH_RETRIEVAL_LIMIT=30
SEARCH_RERANK_CANDIDATES=20
SEARCH_RRF_K=60
SEARCH_RERANK_ENABLED=true
SEARCH_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

LOG_LEVEL=info

# Axiom — dataset blogging-api-prod + ingest token scoped to that dataset
AXIOM_TOKEN=
AXIOM_DATASET=blogging-api-prod
AXIOM_EDGE=us-east-1.aws.edge.axiom.co
