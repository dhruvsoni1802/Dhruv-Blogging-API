# Local development — copy to .env.development
# Use a dedicated Supabase project for dev (not production).

NODE_ENV=development
PORT=3000

# Dev Supabase project (Project Settings → API)
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-dev-key

# Admin — long-lived key for minting short-lived write keys
ADMIN_API_KEY=your-dev-admin-key
DEFAULT_KEY_EXPIRY_HOURS=24

CORS_ORIGIN=http://localhost:5173

# Local semantic search — @xenova/transformers, no API key needed
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Hybrid search tuning (optional)
SEARCH_RETRIEVAL_LIMIT=30
SEARCH_RERANK_CANDIDATES=20
SEARCH_RRF_K=60
SEARCH_RERANK_ENABLED=true
SEARCH_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

LOG_LEVEL=debug

# Axiom (optional in dev — use a separate dev dataset)
# Create dataset blogging-api-dev + ingest token scoped to that dataset
AXIOM_TOKEN=
AXIOM_DATASET=blogging-api-dev
AXIOM_EDGE=us-east-1.aws.edge.axiom.co
